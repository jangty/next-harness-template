{
  "permissions": {
    "allow": [
      "Read(**)",
      "Bash(npm run typecheck:*)",
      "Bash(npm run lint:*)",
      "Bash(npm run test:*)",
      "Bash(npm test:*)",
      "Bash(npm run build:*)",
      "Bash(npx tsc:*)",
      "Bash(npx eslint:*)",
      "Bash(npx prettier:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git blame:*)",
      "Bash(ls:*)"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(npx prisma migrate:*)",
      "Bash(npx prisma db push:*)",
      "Bash(npx prisma migrate deploy:*)",
      "Bash(docker compose:*)",
      "Bash(docker-compose:*)",
      "Bash(ssh:*)",
      "Bash(scp:*)",
      "Bash(./scripts/deploy*)",
      "Bash(npm run deploy:*)"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.local)",
      "Read(.env.*.local)",
      "Read(.env.development)",
      "Read(.env.production)",
      "Read(.env.test)",
      "Read(**/.env)",
      "Read(**/.env.local)",
      "Read(**/.env.*.local)",
      "Read(**/.env.development)",
      "Read(**/.env.production)",
      "Read(**/.env.test)",
      "Edit(.env)",
      "Edit(.env.local)",
      "Edit(.env.*.local)",
      "Edit(.env.development)",
      "Edit(.env.production)",
      "Edit(.env.test)",
      "Edit(**/.env)",
      "Edit(**/.env.local)",
      "Edit(**/.env.*.local)",
      "Edit(**/.env.development)",
      "Edit(**/.env.production)",
      "Edit(**/.env.test)",
      "Write(.env)",
      "Write(.env.local)",
      "Write(.env.*.local)",
      "Write(.env.development)",
      "Write(.env.production)",
      "Write(.env.test)",
      "Write(**/.env)",
      "Write(**/.env.local)",
      "Write(**/.env.*.local)",
      "Write(**/.env.development)",
      "Write(**/.env.production)",
      "Write(**/.env.test)",
      "Edit(.next/**)",
      "Edit(out/**)",
      "Edit(dist/**)",
      "Edit(build/**)",
      "Edit(node_modules/**)",
      "Write(.next/**)",
      "Write(out/**)",
      "Write(dist/**)",
      "Write(build/**)",
      "Write(node_modules/**)",
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Edit|Write|Read|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/scripts/hooks/guard-pretooluse.mjs\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/scripts/hooks/posttooluse-format.mjs\""
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/scripts/hooks/session-start.mjs\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/scripts/hooks/stop-handoff.mjs\""
          }
        ]
      }
    ]
  }
}
